<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="./estilo.css">
    <title>Document</title>
</head>
    <header>
        <h1>site de flores</h1>
    </header>
<body>
    <main>
        
    <button onclick="mostrarMensagem()">Clique no botao!</button>
    <script src="./script.js"></script>

    <p id="saida"></p>
    <script>
        var result = "Meu texto do paragrafo!";
        document.getElementById("saida").innerText = result;
    </script>

   <input type="number" id="entrada" placeholder="Digite sua idade">
   <button onclick="verificar()">Confirme sua idade</button>
   <p>Essa e sua idade!</p>
   <p id="psaida"></p>
   <script>
     function verificar(){
        let idade = document.getElementById("entrada").value;
        document.getElementById("psaida").innerText = idade;
     }
   </script> 

    </main>
</body>
</html>
